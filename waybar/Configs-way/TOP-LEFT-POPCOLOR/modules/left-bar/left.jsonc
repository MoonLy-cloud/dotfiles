{
    "custom/launcher": {
        "format": "󰣇",
        "on-click": "rofi -show drun -theme ~/.config/rofi/launcher.rasi",
        "tooltip": "Launcher"
    },

    "hyprland/workspaces": {
        "active-only": false,
        "all-outputs": true,
        "format": "{name}",
        "on-click": "activate",
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": 5
        }
    }
}